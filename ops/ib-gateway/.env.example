# Copy to .env (gitignored) and fill in. PAPER credentials only — paper creds
# bypass IB-Key 2FA, which is what makes unattended operation possible.
# IMPORTANT: keep the paper account FUNDED (simulated $) — unfunded paper accounts
# break IBC's restart token (IbcAlpha/IBC#345).
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password
# optional: VNC password for debugging the gateway UI via `ssh -L 5900:localhost:5900`
VNC_SERVER_PASSWORD=
